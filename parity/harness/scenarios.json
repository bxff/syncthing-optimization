    {
      "id": "index-sequence-behavior",
      "description": "Validate index/index-update sequence progression and boundary checks.",
      "severity": "P0",
      "required": true,
      "tags": [
        "core",
        "interop"
      ],
      "comparator": "json-equal",
      "go": {
        "command": [
          "go",
          "run",
          "./script/parity_harness_go.go",
          "scenario",
          "index-sequence-behavior"
        ],
        "snapshot_path": "parity/harness/snapshots/go-index-sequence-behavior.json"
      },
      "rust": {
        "command": [
          "cargo",
          "run",
          "--quiet",
          "--manifest-path",
          "syncthing-rs/Cargo.toml",
          "--",
          "interop-scenario",
          "index-sequence-behavior"
        ],
        "snapshot_path": "parity/harness/snapshots/rust-index-sequence-behavior.json"
      }
    },
